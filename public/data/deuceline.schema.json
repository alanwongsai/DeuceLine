{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/deuceline.schema.json",
  "title": "DeucelineDataset",
  "type": "object",
  "required": ["schemaVersion", "rivalry", "matches"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "rivalry": {
      "type": "object",
      "required": ["id", "title", "players"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "players": {
          "type": "object",
          "required": ["alan", "opponent"],
          "additionalProperties": false,
          "properties": {
            "alan": {
              "$ref": "#/$defs/player"
            },
            "opponent": {
              "$ref": "#/$defs/player"
            }
          }
        }
      }
    },
    "matches": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/match"
      }
    }
  },
  "$defs": {
    "player": {
      "type": "object",
      "required": ["displayName"],
      "additionalProperties": false,
      "properties": {
        "displayName": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "match": {
      "type": "object",
      "required": ["id", "date", "surface", "sets"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "surface": {
          "enum": ["hard", "clay", "grass", "astro"]
        },
        "location": {
          "type": "string"
        },
        "sets": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/setScore"
          }
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "setScore": {
      "type": "object",
      "required": ["alan", "opponent"],
      "additionalProperties": false,
      "properties": {
        "alan": {
          "type": "integer",
          "minimum": 0
        },
        "opponent": {
          "type": "integer",
          "minimum": 0
        },
        "tiebreak": {
          "type": "object",
          "required": ["alan", "opponent"],
          "additionalProperties": false,
          "properties": {
            "alan": {
              "type": "integer",
              "minimum": 0
            },
            "opponent": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      }
    }
  }
}
