{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/deuceline.schema.json",
  "title": "DeucelineDataset",
  "type": "object",
  "required": ["schemaVersion", "rivalry", "matches"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": 2
    },
    "rivalry": {
      "type": "object",
      "required": ["id", "title", "players"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "players": {
          "type": "object",
          "required": ["alan", "opponent"],
          "additionalProperties": false,
          "properties": {
            "alan": {
              "$ref": "#/$defs/player"
            },
            "opponent": {
              "$ref": "#/$defs/player"
            }
          }
        }
      }
    },
    "matches": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/match"
      }
    }
  },
  "$defs": {
    "player": {
      "type": "object",
      "required": ["displayName"],
      "additionalProperties": false,
      "properties": {
        "displayName": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "match": {
      "oneOf": [
        {
          "$ref": "#/$defs/detailedMatch"
        },
        {
          "$ref": "#/$defs/scoreMatch"
        }
      ]
    },
    "matchBase": {
      "type": "object",
      "required": ["id", "seq", "surface", "fidelity"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "seq": {
          "type": "integer",
          "minimum": 1
        },
        "date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "surface": {
          "enum": ["hard", "clay", "grass", "astro"]
        },
        "location": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        },
        "fidelity": {
          "enum": ["sets", "matchScore"]
        }
      }
    },
    "detailedMatch": {
      "allOf": [
        {
          "$ref": "#/$defs/matchBase"
        },
        {
          "type": "object",
          "required": ["sets"],
          "properties": {
            "fidelity": {
              "const": "sets"
            },
            "sets": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/setScore"
              }
            }
          },
          "not": {
            "required": ["matchScore"]
          }
        }
      ]
    },
    "scoreMatch": {
      "allOf": [
        {
          "$ref": "#/$defs/matchBase"
        },
        {
          "type": "object",
          "required": ["matchScore"],
          "properties": {
            "fidelity": {
              "const": "matchScore"
            },
            "matchScore": {
              "$ref": "#/$defs/matchScore"
            }
          },
          "not": {
            "required": ["sets"]
          }
        }
      ]
    },
    "matchScore": {
      "type": "object",
      "required": ["alan", "opponent"],
      "additionalProperties": false,
      "properties": {
        "alan": {
          "type": "integer",
          "minimum": 0
        },
        "opponent": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "setScore": {
      "type": "object",
      "required": ["alan", "opponent"],
      "additionalProperties": false,
      "properties": {
        "alan": {
          "type": "integer",
          "minimum": 0
        },
        "opponent": {
          "type": "integer",
          "minimum": 0
        },
        "tiebreak": {
          "$ref": "#/$defs/matchScore"
        }
      }
    }
  }
}
